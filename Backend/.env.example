APP_NAME=Engineering Knowledge Search Platform
DEBUG=false

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://eksp_user:eksp_password@postgres:5432/eksp_db

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Internal service URLs
AI_PIPELINE_URL=http://ai-pipeline:8000

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=eksp_knowledge

# RAG score thresholds
RAG_HIGH_THRESHOLD=0.80
RAG_LOW_THRESHOLD=0.60
